#!/bin/sh
# 提交前密钥扫描（gitleaks）。
#
# 背景：2026-07-20 发现本仓库曾把一台服务器的明文 SSH 密码硬编码进 59 个文件并
# 提交进 git 历史（已清理+改名重写历史），装这个钩子防止同类问题再发生——
# 提交前自动扫描本次改动，发现疑似密钥/密码/token 就直接拦下提交，不让它进历史。
#
# 安装方式（clone 后一次性执行，或直接 `npm install` 触发 package.json 的
# prepare 脚本自动执行）：
#   git config core.hooksPath .githooks
#
# 需要本机装有 gitleaks（https://github.com/gitleaks/gitleaks）：
#   Windows: choco install gitleaks   /   macOS: brew install gitleaks
#   或从 release 页面下载对应平台的二进制放进 PATH。

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "⚠️  未检测到 gitleaks，跳过本次密钥扫描（建议安装：https://github.com/gitleaks/gitleaks/releases）"
  exit 0
fi

gitleaks git --staged --no-banner -v --config .gitleaks.toml .
status=$?

if [ $status -ne 0 ]; then
  echo ""
  echo "🛑 gitleaks 检测到本次提交里可能包含密钥/密码/token，提交已被拦截。"
  echo "   确认是误报的话，可以在 .gitleaks.toml 里加白名单规则；确认是真的密钥，"
  echo "   请改用环境变量/密钥管理工具，不要提交进代码。"
  exit 1
fi

exit 0
